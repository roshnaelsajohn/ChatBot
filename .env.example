# ============================================================
# ChatBot Application - Environment Variables Template
# ============================================================
# This file is SAFE to commit. It contains no real secrets.
# To get started:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values in .env
# ============================================================

# ---------------------------
# Google Gemini API
# ---------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------
# Backend Configuration
# ---------------------------
FLASK_DEBUG=True
CHROMA_DB_PATH=./chroma_db
MAX_UPLOAD_SIZE_MB=16

# ---------------------------
# SSL / HuggingFace Hub
# ---------------------------
HF_HUB_DISABLE_SSL_VERIFY=1

# ---------------------------
# Frontend (Vite / React)
# ---------------------------
# For local development use: http://localhost:5001/api
# For Docker use: /api
VITE_API_BASE_URL=http://localhost:5001/api

# ---------------------------
# Anthropic (Claude)
# ---------------------------
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------
# OpenAI
# ---------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------
# LangSmith Tracing
# ---------------------------
# Get your API key from: https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=TestFlyAI
